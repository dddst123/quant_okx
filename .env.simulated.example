# Safe public demo template.
# Copy to .env.simulated, fill your demo-trading API keys, and keep all tuned
# strategy parameters in the ignored local file only.

OKX_ENV_PROFILE=simulated
OKX_SIMULATED=true
OKX_DRY_RUN=true

# Demo trading API key set from OKX simulated trading.
OKX_API_KEY=your_demo_api_key
OKX_API_SECRET=your_demo_api_secret
OKX_API_PASSPHRASE=your_demo_api_passphrase

OKX_BASE_URL=https://www.okx.com

OKX_HTTP_MAX_RETRIES=3
OKX_HTTP_RETRY_BACKOFF_SEC=1
OKX_LOG_PATH=logs/okx_quant_simulated.log
OKX_LOG_MAX_BYTES=5000000
OKX_LOG_BACKUP_COUNT=5
OKX_ALERT_WEBHOOK_URL=
OKX_ALERT_FORMAT=slack
OKX_ALERT_TIMEOUT_SEC=10
OKX_ALERT_ERROR_EVERY_N=3

OKX_FACTOR_STATE_PATH=state/factor_bot_state.simulated.json
OKX_FACTOR_BACKTEST_OUTPUT_DIR=reports/backtests
OKX_FACTOR_WALK_FORWARD_OUTPUT_DIR=reports/walk_forward
OKX_FACTOR_GUARDIAN_OUTPUT_DIR=reports/guardian/simulated
OKX_FACTOR_GUARDIAN_STATE_PATH=state/factor_guardian_state.simulated.json

# Add private factor / market-state / risk overrides only in .env.simulated.
