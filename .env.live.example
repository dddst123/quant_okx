# Safe public live template.
# Copy to .env.live, fill your live API keys, keep OKX_DRY_RUN=true until demo
# forward testing is stable, and keep all tuned strategy parameters local.

OKX_ENV_PROFILE=live
OKX_SIMULATED=false
OKX_DRY_RUN=true

# Use a live API key without withdrawal permission.
OKX_API_KEY=your_live_api_key
OKX_API_SECRET=your_live_api_secret
OKX_API_PASSPHRASE=your_live_api_passphrase

OKX_BASE_URL=https://www.okx.com

OKX_HTTP_MAX_RETRIES=3
OKX_HTTP_RETRY_BACKOFF_SEC=1
OKX_LOG_PATH=logs/okx_quant_live.log
OKX_LOG_MAX_BYTES=5000000
OKX_LOG_BACKUP_COUNT=5
OKX_ALERT_WEBHOOK_URL=
OKX_ALERT_FORMAT=slack
OKX_ALERT_TIMEOUT_SEC=10
OKX_ALERT_ERROR_EVERY_N=3

OKX_FACTOR_STATE_PATH=state/factor_bot_state.live.json
OKX_FACTOR_BACKTEST_OUTPUT_DIR=reports/backtests
OKX_FACTOR_WALK_FORWARD_OUTPUT_DIR=reports/walk_forward
OKX_FACTOR_GUARDIAN_OUTPUT_DIR=reports/guardian/live
OKX_FACTOR_GUARDIAN_STATE_PATH=state/factor_guardian_state.live.json

# Add private factor / market-state / risk overrides only in .env.live.
