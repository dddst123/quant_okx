# Shared base template.
# Copy this file to .env only if you want common settings shared by both
# simulated and live profiles.
#
# Keep API keys, tuned factor parameters, and any private research overrides in
# ignored local files only:
# - .env.simulated
# - .env.live
# - or another file passed through OKX_ENV_FILE

OKX_ENV_PROFILE=simulated
# OKX_ENV_FILE=.env.simulated

# Leave credentials blank here if you prefer to store them only in the
# profile-specific files above.
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

OKX_SIMULATED=true
OKX_DRY_RUN=true
OKX_BASE_URL=https://www.okx.com

# Operational settings
OKX_HTTP_MAX_RETRIES=3
OKX_HTTP_RETRY_BACKOFF_SEC=1
OKX_LOG_PATH=logs/okx_quant.log
OKX_LOG_MAX_BYTES=5000000
OKX_LOG_BACKUP_COUNT=5
OKX_ALERT_WEBHOOK_URL=
OKX_ALERT_FORMAT=slack
OKX_ALERT_TIMEOUT_SEC=10
OKX_ALERT_ERROR_EVERY_N=3

# Local state and report paths
OKX_FACTOR_STATE_PATH=state/factor_bot_state.json
OKX_FACTOR_BACKTEST_OUTPUT_DIR=reports/backtests
OKX_FACTOR_WALK_FORWARD_OUTPUT_DIR=reports/walk_forward
OKX_FACTOR_GUARDIAN_OUTPUT_DIR=reports/guardian
OKX_FACTOR_GUARDIAN_STATE_PATH=state/factor_guardian_state.json

# Advanced factor / market-state / risk overrides are intentionally omitted
# from tracked templates. Keep private strategy parameters in ignored local
# env files only.
